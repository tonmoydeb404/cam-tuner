# Enable workspace protocol
link-workspace-packages=true

# Auto install peers
auto-install-peers=true

# Strict peer dependencies (recommended for monorepos)
strict-peer-dependencies=false

# Save exact versions
save-exact=false

# Hoist all dependencies to root node_modules
hoist=true

# Shamefully hoist (for tools that need flat node_modules)
shamefully-hoist=false

# Shared workspace lockfile
shared-workspace-lockfile=true

# Use node_modules linker
node-linker=hoisted
