{
  "name": "@cam-tuner/extension",
  "description": "CamTuner browser extension for webcam configuration",
  "private": true,
  "version": "2.0.9",
  "type": "module",
  "scripts": {
    "copy:wasm": "node scripts/copy-mediapipe-wasm.mjs",
    "build:adapter": "node scripts/build-mediapipe-adapter.mjs",
    "dev": "node scripts/copy-mediapipe-wasm.mjs && node scripts/build-mediapipe-adapter.mjs && wxt",
    "dev:firefox": "node scripts/copy-mediapipe-wasm.mjs && node scripts/build-mediapipe-adapter.mjs && wxt -b firefox",
    "build": "node scripts/copy-mediapipe-wasm.mjs && node scripts/build-mediapipe-adapter.mjs && wxt build",
    "build:firefox": "node scripts/copy-mediapipe-wasm.mjs && node scripts/build-mediapipe-adapter.mjs && wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tabler/icons-react": "^3.41.1",
    "@workspace/stream-config": "workspace:*",
    "@workspace/ui": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.27.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wxt": "^0.20.19"
  }
}
